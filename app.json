{
  "expo": {
    "name": "Motion Physio",
    "slug": "motionplusphysio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.motionphysio.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "bbf995bf-0eed-4705-9059-347c88864746"
      }
    },
    "owner": "vijaybuilds",
    "plugins": [
      "expo-font"
    ]
  }
}
